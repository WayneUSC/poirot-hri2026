<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- 左侧标签栏 -->
        <LinearLayout
            android:id="@+id/leftPanel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@android:color/darker_gray"
            android:padding="8dp">

            <Button
                android:id="@+id/exit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXIT"
                android:padding="1dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/tabPublicChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Public Clue"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:textColor="@android:color/white" />

            <ScrollView
                android:id="@+id/scrollChapterContainer"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:background="#AAA"
                android:layout_gravity="start">

                <LinearLayout
                    android:id="@+id/chapterContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp" />
            </ScrollView>

<!--            <androidx.constraintlayout.widget.ConstraintLayout-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="match_parent">-->
            <!-- 准备进入下一幕按钮 -->
            <Button
                android:id="@+id/btnPrepareNextAct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:backgroundTint="@color/purple_500"
                android:enabled="true"
                android:padding="12dp"
                android:text="Next Chapter"
                android:textColor="@android:color/white"
                android:textSize="16sp" />
<!--            </androidx.constraintlayout.widget.ConstraintLayout>-->
        </LinearLayout>

        <!-- 右侧聊天内容显示区 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_selected_role"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="character chosen"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:gravity="center"/>

            <ViewFlipper
                android:id="@+id/viewSwitcher"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- 公共聊天室 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView_public"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#F0F8FF"/><!-- 设置公共聊天室背景颜色 -->

                <!-- 剧本 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView_script"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:scrollbars="vertical"
                    android:background="#FFFACD"/> <!-- 设置背景颜色 -->

                <!-- 线索 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView_clue"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:scrollbars="vertical"
                    android:background="#E6E6FA"/>


            </ViewFlipper>
        </LinearLayout>
    </LinearLayout>

    <!-- 底部的输入框和发送按钮 -->
